# ═══════════════════════════════════════════════════════════
# HOME LAB .gitignore
# ═══════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────
# SECRETS & CREDENTIALS (NEVER COMMIT!)
# ─────────────────────────────────────────────────────────────
infrastructure/secrets/
infrastructure/secrets/*
**/.env
**/.env.*
.env
.env.local
.env.production
.env.*.local
CREDENTIALS.md
**/credentials.txt
**/passwords.txt
**/*secret*
**/*password*
**/*credential*

# SSH Keys
*.pem
*.key
id_rsa
id_rsa.pub
*.ppk
# Named SSH keys (explicit — pattern matching tidak cukup)
personal_github
personal_github.pub
github_homelab
github_homelab.pub

# ─────────────────────────────────────────────────────────────
# DATA & DATABASES (Too large, not code)
# ─────────────────────────────────────────────────────────────
data/
data/*
**/data/postgres/
**/data/mongo/
**/data/redis/
**/data/elasticsearch/
**/data/backups/
*.sql
*.dump
*.backup

# ─────────────────────────────────────────────────────────────
# DOCKER VOLUMES & BUILD
# ─────────────────────────────────────────────────────────────
infrastructure/docker/volumes/
**/volumes/
*.vhdx
*.vhd

# ─────────────────────────────────────────────────────────────
# LOGS
# ─────────────────────────────────────────────────────────────
*.log
logs/
**/logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ─────────────────────────────────────────────────────────────
# OS & EDITOR
# ─────────────────────────────────────────────────────────────
# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~
.directory

# VSCode
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# JetBrains IDEs
.idea/
*.iml
*.ipr
*.iws

# ─────────────────────────────────────────────────────────────
# TEMPORARY FILES & TEST OUTPUTS
# ─────────────────────────────────────────────────────────────
tmp/
temp/
*.tmp
*.temp
*.swp
*.swo
*~
test.pdf
test-*.pdf

# ─────────────────────────────────────────────────────────────
# DEPENDENCIES (Too large, can be reinstalled)
# ─────────────────────────────────────────────────────────────
node_modules/
vendor/
bower_components/
__pycache__/
*.pyc
*.pyo
.Python
venv/
ENV/
env/

# ─────────────────────────────────────────────────────────────
# BUILD OUTPUTS
# ─────────────────────────────────────────────────────────────
dist/
build/
*.exe
*.out
*.o
*.so
*.dylib
*.dll

# ─────────────────────────────────────────────────────────────
# PERSONAL NOTES (Optional, keep private)
# ─────────────────────────────────────────────────────────────
NOTES.md
TODO-PERSONAL.md
BRAINSTORM.md

# ═══════════════════════════════════════════════════════════
# END OF .gitignore
# ═══════════════════════════════════════════════════════════
