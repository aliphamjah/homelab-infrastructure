# ============================================
# Home Lab Development - Global .gitignore
# ============================================

# ============================================
# CRITICAL: Sensitive Data (NEVER COMMIT!)
# ============================================
**/secrets/
**/.env
**/.env.*
!**/.env.example
**/credentials.json
**/service-account.json
**/*-key.json
**/*.pem
**/*.key
**/*.crt
**/id_rsa*
**/.aws/
**/.kube/config

# ============================================
# Data Directories (Database Files)
# ============================================
data/postgres/
data/mongo/
data/redis/
data/mysql/
data/elasticsearch/
data/kafka/
data/grafana/
data/prometheus/

# Keep backup directories structure but ignore contents
data/backups/*
!data/backups/.gitkeep
!data/backups/daily/.gitkeep
!data/backups/weekly/.gitkeep
!data/backups/monthly/.gitkeep

# ============================================
# Docker Volumes (Dynamic Data)
# ============================================
infrastructure/docker/volumes/*
!infrastructure/docker/volumes/.gitkeep

# ============================================
# Logs & Temporary Files
# ============================================
*.log
*.log.*
logs/
tmp/
temp/
*.tmp
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ============================================
# IDE & Editor Files
# ============================================
.vscode/
.idea/
*.sublime-*
*.code-workspace

# Keep shared IDE configs (optional)
!.vscode/settings.json
!.vscode/extensions.json

# ============================================
# Language-Specific
# ============================================

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
dist/
build/
.next/
.nuxt/
.cache/

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
env/
ENV/
.venv
*.egg-info/
.pytest_cache/
.mypy_cache/

# Go
vendor/
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out
go.work

# Rust
target/
Cargo.lock
**/*.rs.bk

# PHP
vendor/
composer.lock

# ============================================
# OS-Specific
# ============================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ============================================
# Keep Structure Files
# ============================================
!.gitkeep
!README.md
!.gitignore
